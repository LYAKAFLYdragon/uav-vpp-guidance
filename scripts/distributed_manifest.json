          "paper_claim": "Control group for domain randomization"
        },
        {
          "id": "E3",
          "name": "domain_randomization_eval",
          "description": "Evaluate DR-trained policy under perturbation scales",
          "script": "python scripts/evaluate_domain_rand_v2.py",
          "input_checkpoint": "outputs/experiments/no_prediction_vpp_ppo_domain_rand_s0/checkpoints/best.pt",
          "scales": [0.0, 0.5, 1.0, 1.5, 2.0],
          "episodes_per_scale": 30,
          "hardware": "CPU",
          "estimated_minutes": 60,
          "paper_claim": "Robustness under ±20% disturbance (25.8% vulnerability)"
        }
      ]
    },
    {
      "group_id": "F",
      "name": "capture_and_inference",
      "description": "Capture region heatmaps and inference timing",
      "estimated_total_hours": 2.0,
      "hardware": "CPU",
      "experiments": [
        {
          "id": "F1",
          "name": "capture_region_highres",
          "description": "600-point capture region grid",
          "script": "python scripts/compute_capture_region.py",
          "input_checkpoint": "outputs/experiments/baseline_10seed_s0/checkpoints/best.pt",
          "grid": {"distances": 10, "headings": 12, "speed_ratios": 5},
          "episodes_per_point": 5,
          "hardware": "CPU",
          "estimated_minutes": 90,
          "paper_claim": "Capture region comparison between VPP+LOS and PN"
        },
        {
          "id": "F2",
          "name": "inference_time_benchmark",
          "description": "PPO inference and CEM optimization latency",
          "script": "python scripts/benchmark_inference_time.py",
          "input_checkpoint": "outputs/experiments/baseline_10seed_s0/checkpoints/best.pt",
          "hardware": "CPU",
          "estimated_minutes": 10,
          "paper_claim": "PPO inference <1ms, total control cycle <5ms"
        }
      ]
    }
  ],
  "aggregation": {
    "scripts": [
      {"name": "aggregate_10seed_results.py", "output": "docs/results/10seed_evaluation/summary_10seed_full.md"},
      {"name": "aggregate_crossing_generalization.py", "output": "docs/results/crossing_generalization/full_grid_summary.md"},
      {"name": "aggregate_domain_rand.py", "output": "docs/results/domain_randomization/distributed_summary.md"},
      {"name": "aggregate_predictor_stratification.py", "output": "docs/results/predictor_stratification/10seed_summary.md"}
